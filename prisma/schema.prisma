generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String         @id @default(cuid())
  name             String
  email            String         @unique
  password         String?
  image            String?
  role             String         @default("student")
  stripeCustomerId String?
  phone            String?
  country          String?
  city             String?
  job              String?
  bio              String?
  interests        String[]       @default([])
  enrollments      Enrollment[]
  payments         Payment[]
  conversations    Conversation[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model Course {
  id              String        @id @default(cuid())
  title           String
  titleEn         String?       // override en inglés — si es null, se usa title
  slug            String        @unique
  shortDesc       String
  shortDescEn     String?       // override en inglés — si es null, se usa shortDesc
  description     String
  descriptionEn   String?       // override en inglés — si es null, se usa description
  price           Float
  currency        String        @default("USD")
  stripePriceId   String?
  stripeProductId String?
  thumbnail       String?
  isPublished     Boolean       @default(false)
  isFree          Boolean       @default(false)
  totalHours      Float?        // intensidad horaria total del programa
  durationWeeks   Int?          // duración estimada en semanas
  videoUrl        String?       // link de YouTube mostrado en la página del programa
  content         String?       // JSON: eyebrow/duración/modalidad/nivel/módulos/incluye/para quién/resultado
  enrollments        Enrollment[]
  materials          Material[]
  liveSessions       LiveSession[]
  payments           Payment[]
  conversations      Conversation[]
  exclusiveResources ExclusiveResource[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model Enrollment {
  id                String       @id @default(cuid())
  userId            String
  courseId          String
  status            String       @default("active")
  progress          Int          @default(0)   // % de avance 0-100
  hoursCompleted    Float        @default(0)   // horas realizadas
  completedAt       DateTime?
  certificateNumber String?      @unique
  certificateUrl    String?
  user              User         @relation(fields: [userId], references: [id])
  course            Course       @relation(fields: [courseId], references: [id])
  attendances       Attendance[]
  enrolledAt        DateTime     @default(now())

  @@unique([userId, courseId])
}

model Material {
  id           String   @id @default(cuid())
  courseId     String
  title        String
  description  String?
  type         String
  fileUrl      String?
  videoUrl     String?
  linkUrl      String?
  moduleNumber Int      @default(1)
  order        Int      @default(0)
  isVisible    Boolean  @default(true)
  course       Course   @relation(fields: [courseId], references: [id])
  createdAt    DateTime @default(now())
}

model LiveSession {
  id           String       @id @default(cuid())
  courseId     String
  title        String
  description  String?
  scheduledAt  DateTime
  durationMin  Int          @default(90)  // duración en minutos (para sumar horas)
  joinUrl      String?
  recordingUrl String?
  isCompleted  Boolean      @default(false)
  course       Course       @relation(fields: [courseId], references: [id])
  attendances  Attendance[]
  createdAt    DateTime     @default(now())
}

model Attendance {
  id            String      @id @default(cuid())
  enrollmentId  String
  liveSessionId String
  status        String      @default("present")  // present | absent | late
  enrollment    Enrollment  @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  liveSession   LiveSession @relation(fields: [liveSessionId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@unique([enrollmentId, liveSessionId])
}

model Payment {
  id              String    @id @default(cuid())
  userId          String
  courseId        String
  stripeSessionId String?
  stripePaymentId String?
  amount          Float
  currency        String    @default("USD")
  status          String    @default("pending")
  paidAt          DateTime?
  user            User      @relation(fields: [userId], references: [id])
  course          Course    @relation(fields: [courseId], references: [id])
  createdAt       DateTime  @default(now())
}

model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @default(now())
}

model Post {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  category    String
  excerpt     String
  content     String
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Conversation {
  id        String        @id @default(cuid())
  userId    String
  courseId  String?
  title     String?
  user      User          @relation(fields: [userId], references: [id])
  course    Course?       @relation(fields: [courseId], references: [id])
  messages  ChatMessage[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model ChatMessage {
  id             String       @id @default(cuid())
  conversationId String
  role           String       // "user" | "assistant"
  content        String       @db.Text
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  createdAt      DateTime     @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  type      String   // "duplicate_purchase_blocked" | "refund_synced"
  message   String
  metadata  String?  // JSON con datos extra (email, curso, monto, etc.)
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model ExclusiveResource {
  id          String   @id @default(cuid())
  courseId    String?
  title       String
  description String?
  type        String   // "audio" | "video" | "document"
  fileUrl     String
  duration    Int?     // segundos
  isVisible   Boolean  @default(true)
  order       Int      @default(0)
  course      Course?  @relation(fields: [courseId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
